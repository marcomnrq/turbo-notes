{
  "mcp": {
    "servers": {
      "shadcn": {
        "command": "npx",
        "args": [
          "shadcn@latest",
          "mcp"
        ]
      },
      "playwright": {
        "type": "stdio",
        "command": "npx",
        "args": [
          "@playwright/mcp@latest"
        ],
        "env": {}
      },
      "figma": {
        "url": "https://mcp.figma.com/mcp",
        "type": "http"
      }
    }
  }
}
