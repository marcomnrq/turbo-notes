# Backend environment. All values are optional for local dev — defaults are
# sensible for running with `python manage.py runserver` + SQLite. Copy this
# file to `.env` (or export the vars) to override.

# Django secret key. The bundled insecure default is fine for local dev only.
SECRET_KEY=change-me-in-production

# Run in debug mode. Leave true for local development.
DEBUG=true

# Comma-separated list of allowed hosts.
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Comma-separated list of allowed CORS origins (the frontend origin).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Comma-separated list of trusted CSRF origins.
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database URL. Omit to use the default SQLite database (db.sqlite3).
# For docker-compose Postgres, use something like:
# DATABASE_URL=postgres://turbonotes:turbonotes@db:5432/turbonotes
