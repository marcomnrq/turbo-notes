{
  "name": "turbo-notes",
  "version": "0.1.0",
  "private": true,
  "description": "Turbo Notes — orchestration for local dev (backend + frontend in parallel).",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c yellow,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "cd backend && ./.venv/bin/python manage.py runserver 0.0.0.0:8000",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "cd frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
