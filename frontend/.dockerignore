# Keep the build context lean and avoid shadowing container-installed deps.

# Node / Next build artifacts
node_modules/
.next/
out/
build/
dist/
*.tsbuildinfo

# Git / editor / OS
.git/
.gitignore
.idea/
.vscode/
.DS_Store

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env files (examples are kept; real secrets never enter the image)
.env
.env.*
!.env.example

# Docker
Dockerfile
.dockerignore
